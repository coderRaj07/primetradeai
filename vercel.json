{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "routePrefix": "/_/backend",
      "entrypoint": "api/index.py"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/_/backend/api/$1" },
    { "source": "/docs", "destination": "/_/backend/docs" },
    { "source": "/redoc", "destination": "/_/backend/redoc" },
    { "source": "/openapi.json", "destination": "/_/backend/openapi.json" }
  ]
}
